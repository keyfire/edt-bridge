<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<!-- Early startup makes EDT activate this bundle (and start the MCP server) on launch.
     Alternative (headless / no UI): an Equinox DS component with immediate=true. -->
<plugin>
   <extension point="org.eclipse.ui.startup">
      <startup class="io.github.keyfire.edtbridge.EarlyStartup"/>
   </extension>
   <extension point="org.eclipse.ui.preferencePages">
      <page id="io.github.keyfire.edtbridge.preferences"
            name="EDT-Bridge"
            class="io.github.keyfire.edtbridge.ui.EdtBridgePreferencePage"/>
   </extension>
</plugin>
